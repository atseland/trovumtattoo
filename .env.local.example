# Miljoevariabler
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Maa matche Clerk-instansen som ogsaa har JWT-template med navn "convex"
CLERK_JWT_ISSUER_DOMAIN=https://united-piranha-14.clerk.accounts.dev
# JWKS for samme instans:
# https://united-piranha-14.clerk.accounts.dev/.well-known/jwks.json
E2E_CLERK_USER_EMAIL=

# Sentry (sett DSN for aa aktivere feilsporing)
NEXT_PUBLIC_SENTRY_DSN=
# Brukes av Sentry CLI / sourcemap upload i CI. Skal ikke eksponeres til klienten.
SENTRY_AUTH_TOKEN=

# Mail (fast one.com-oppsett, sett paa Convex med: npx convex env set <KEY> <value>)
# MAIL_HOST_IMAP=imap.one.com
# MAIL_PORT_IMAP=993
# MAIL_HOST_SMTP=send.one.com
# MAIL_PORT_SMTP=465
# MAIL_USERNAME=ellen@trovumtattoo.no
# MAIL_PASSWORD=
# MAIL_FROM=Trovum Tattoo <ellen@trovumtattoo.no>

# Push-varsler (VAPID keys, sett paa Convex med: npx convex env set <KEY> <value>)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Klienten trenger public VAPID key for aa kunne abonnere paa push-varsler
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
